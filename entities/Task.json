{
  "name": "Task",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo da tarefa"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o da tarefa"
    },
    "child_id": {
      "type": "string",
      "description": "ID da crian\u00e7a relacionada"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Data limite"
    },
    "status": {
      "type": "string",
      "enum": [
        "pendente",
        "em_andamento",
        "concluida"
      ],
      "default": "pendente",
      "description": "Status da tarefa"
    },
    "priority": {
      "type": "string",
      "enum": [
        "baixa",
        "media",
        "alta"
      ],
      "default": "media",
      "description": "Prioridade"
    },
    "assigned_to": {
      "type": "string",
      "description": "Email do respons\u00e1vel"
    }
  },
  "required": [
    "title"
  ]
}